PORT=5000
MONGO_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/kaammitra
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRE=30d

FRONTEND_URL=http://localhost:5173

# OTP Configuration
# OTP_MODE can be 'demo' or 'production'
OTP_MODE=demo
# OTP_PROVIDER can be 'msg91', 'fast2sms', 'twilio'
OTP_PROVIDER=msg91
OTP_API_KEY=your_api_key_here
OTP_SENDER_ID=your_sender_id_here
